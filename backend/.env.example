# Copy this file to .env and replace every placeholder before running the app.
APP_NAME=Car Dealership Inventory Management System API
APP_VERSION=0.1.0
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://username:password@localhost:5432/car_dealership
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
